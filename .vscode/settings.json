{
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "editor.formatOnSave": true,
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/target/**": true
  },
  "git.detectSubmodules": true,
  "git.repositoryScanIgnoredFolders": [
    "node_modules",
    // "vendor/oh-my-tmux/plugins",
    // "vendor/oh-my-zsh/custom/plugins",
    // "vendor/oh-my-zsh/custom/themes",
    "vendor/vim/pack"
  ],
  "python.analysis.typeCheckingMode": "standard",
  "rust-analyzer.linkedProjects": [
    "${workspaceFolder}/turtle/Cargo.toml"
  ],
  // Exclude node_modules and vendor directories from search results, and also exclude any files with the .code-search extension.
  "search.exclude": {
    "**/*.code-search": true,
    "**/node_modules": true,
    "**/vendor": true
  },
  "shellcheck.customArgs": [
    "-x"
  ],
  "shellcheck.enable": true,
  // Automation terminal: used by Copilot, tasks, and extensions.
  // Bypasses the full interactive .zshrc (no oh-my-zsh, p10k, plugins, banners).
  "terminal.integrated.automationProfile.osx": {
    "env": {
      "ZDOTDIR": "/Users/Aaron.Samuel/.dot/config/automation"
    },
    "path": "/bin/zsh"
  },
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.defaultProfile.osx": "zsh"
}
